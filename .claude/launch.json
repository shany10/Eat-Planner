{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--port", "3099"],
      "port": 3099,
      "autoPort": false
    },
    {
      "name": "frontend-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["frontend/.output/server/index.mjs"],
      "port": 3098,
      "autoPort": true
    }
  ]
}
