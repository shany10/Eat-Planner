# -----------------------------------------------------------------------------
# Eat Planner - environment example
# Copy this file to .env before starting the project.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
NODE_PORT=3000

# -----------------------------------------------------------------------------
# Docker / MongoDB
# Used by docker-compose.yml and by the backend connection string.
# -----------------------------------------------------------------------------
MONGO_USER=root
MONGO_PASS=example
MONGO_DATABASE=mydb
MONGODB_URI=mongodb://root:example@mongo:27017/mydb?authSource=admin

# -----------------------------------------------------------------------------
# Backend security
# Change these values in production.
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_with_a_long_random_secret
TOTP_ISSUER=EatPlanner
TOTP_ENCRYPTION_KEY=change_me_with_another_long_random_secret

# -----------------------------------------------------------------------------
# Frontend / Nuxt
# In Docker, the frontend talks to the backend through the service name backend.
# -----------------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:3001
APP_URL=http://localhost:3001
NUXT_BACKEND_BASE_URL=http://backend:3000
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NUXT_DEVTOOLS=false
NITRO_HOST=0.0.0.0
NITRO_PORT=3001

# Optional Nuxt session secret, kept for compatibility if session features are added.
NUXT_SESSION_SECRET=change_me_with_a_long_random_session_secret

# WebRTC video calls. Public URL of the backend Socket.IO server as seen by the browser.
# In production this MUST be the public HTTPS backend URL (e.g. https://api.mydomain.com),
# otherwise the browser cannot reach the signaling server.
NUXT_PUBLIC_REALTIME_BASE_URL=http://localhost:3000

# ICE servers for WebRTC. In local dev the default public STUN is enough.
# In production, behind strict NAT/firewalls, add a TURN server (e.g. coturn) or
# some calls will never connect. Leave TURN_* empty to use STUN only.
NUXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
NUXT_PUBLIC_TURN_URL=
NUXT_PUBLIC_TURN_USERNAME=
NUXT_PUBLIC_TURN_CREDENTIAL=

# Comma-separated list of origins allowed by the backend Socket.IO CORS.
# In production set this to your public frontend domain(s), e.g. https://mydomain.com
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001

# Reverse proxy Caddy (docker-compose.caddy.yml) : domaines publics de production.
# APP_DOMAIN -> frontend, API_DOMAIN -> backend. Laisser vide en dev.
APP_DOMAIN=mondomaine.com
API_DOMAIN=api.mondomaine.com
# Monitoring derriere Caddy (docker-compose.monitoring-caddy.yml), optionnel.
# SENTRY_DOMAIN -> GlitchTip, STATS_DOMAIN -> Umami.
SENTRY_DOMAIN=sentry.mondomaine.com
STATS_DOMAIN=stats.mondomaine.com

# -----------------------------------------------------------------------------
# Google OAuth
# Required only if Google Sign-In is enabled.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id

# -----------------------------------------------------------------------------
# Admin bootstrap / seed accounts
# Used by backend startup bootstrap and npm run seed.
# -----------------------------------------------------------------------------
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=System
ADMIN_EMAIL=admin@eatplanner.local
ADMIN_PASSWORD=Admin123!

# Supplier portal demo account created automatically at backend startup.
SUPPLIER_PORTAL_EMAIL=tovincentngo@gmail.com
SUPPLIER_PORTAL_PASSWORD=Fournisseur123!

# -----------------------------------------------------------------------------
# Emails
# Local development uses Mailpit:
# - SMTP: mailpit:1025 from Docker
# - Web UI: http://localhost:8025
# Set MAIL_MODE=log to print emails in backend logs instead.
# Set MAIL_MODE=smtp to send emails through SMTP.
# -----------------------------------------------------------------------------
PASSWORD_RESET_TTL_MINUTES=30
MAIL_MODE=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_TLS_REJECT_UNAUTHORIZED=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Eat Planner <orders@eatplanner.local>
MAIL_APP_NAME=Eat Planner

# -----------------------------------------------------------------------------
# SMTP aliases also supported by the backend
# Uncomment if you prefer SMTP_* variable names instead of MAIL_*.
# -----------------------------------------------------------------------------
# SMTP_MODE=log
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=EatPlanner <no-reply@example.com>
# SMTP_APP_NAME=EatPlanner

# -----------------------------------------------------------------------------
# Backend error reporting (Sentry SDK -> GlitchTip)
# DSN comes from the GlitchTip project page. Inside Docker the host must be the
# service name "glitchtip-web"; outside Docker use localhost:8000.
# Leave SENTRY_DSN empty to disable error reporting (recommended by default).
# To enable with docker-compose.monitoring.yml + GlitchTip:
# 1. Open http://localhost:8000
# 2. Create a backend project
# 3. Copy the DSN and replace the public key / project id below
# -----------------------------------------------------------------------------
SENTRY_DSN=
# SENTRY_DSN=http://your_public_key@glitchtip-web:8000/1
SENTRY_TRACES_SAMPLE_RATE=0.01

# -----------------------------------------------------------------------------
# Frontend error reporting (Sentry Nuxt -> GlitchTip)
# Browser-side DSN must use the host reachable from the browser (localhost);
# server-side (SSR, in the container) must use the docker service glitchtip-web.
# Leave empty to disable. Use a dedicated GlitchTip project for the frontend.
# -----------------------------------------------------------------------------
NUXT_PUBLIC_SENTRY_DSN=
SENTRY_SERVER_DSN=
# NUXT_PUBLIC_SENTRY_DSN=http://your_public_key@localhost:8000/2
# SENTRY_SERVER_DSN=http://your_public_key@glitchtip-web:8000/2

# -----------------------------------------------------------------------------
# Frontend web analytics (Umami)
# NUXT_PUBLIC_UMAMI_SRC: tracking script URL (browser -> localhost).
# NUXT_PUBLIC_UMAMI_WEBSITE_ID: id of the website created in the Umami UI.
# Leave the website id empty to disable analytics.
# To enable:
# 1. Open http://localhost:3002
# 2. Login with admin / umami on first run
# 3. Create a website, copy its website id
# 4. Fill the two values below
# -----------------------------------------------------------------------------
NUXT_PUBLIC_UMAMI_SRC=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
# NUXT_PUBLIC_UMAMI_SRC=http://localhost:3002/script.js
# NUXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id

# -----------------------------------------------------------------------------
# Monitoring - GlitchTip (error tracking)
# Used by docker-compose.monitoring.yml. Web UI exposed on http://localhost:8000
# -----------------------------------------------------------------------------
GLITCHTIP_DB_USER=glitchtip
GLITCHTIP_DB_PASS=glitchtip
GLITCHTIP_DB_NAME=glitchtip
GLITCHTIP_SECRET_KEY=change_me_with_a_long_random_secret
# En prod derriere Caddy, mets l'URL HTTPS publique : https://sentry.mondomaine.com
GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_FROM_EMAIL=glitchtip@eatplanner.local
# consolemail:// prints emails to the logs. For real delivery use e.g.
# smtp://user:pass@smtp.example.com:587
GLITCHTIP_EMAIL_URL=consolemail://
# Set to false once the first admin account has been created.
GLITCHTIP_ENABLE_REGISTRATION=true

# -----------------------------------------------------------------------------
# Monitoring - Umami (web analytics)
# Used by docker-compose.monitoring.yml. Web UI exposed on http://localhost:3002
# Default credentials on first run: admin / umami
# -----------------------------------------------------------------------------
UMAMI_DB_USER=umami
UMAMI_DB_PASS=umami
UMAMI_DB_NAME=umami
UMAMI_APP_SECRET=change_me_with_a_long_random_secret
